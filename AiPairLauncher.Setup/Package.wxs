<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="AiPairLauncher"
    Manufacturer="AiPairLauncher contributors"
    Version="$(var.ProductVersion)"
    UpgradeCode="{C8D10693-FD7C-49A4-B797-76C43A43C2F4}"
    Scope="perMachine"
    InstallerVersion="500"
    Language="1033"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of AiPairLauncher is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AiPairLauncherIcon" SourceFile="..\assets\AiPairLauncher.ico" />
    <Property Id="ARPPRODUCTICON" Value="AiPairLauncherIcon" />
    <WixVariable Id="WixUILicenseRtf" Value="Assets\License.rtf" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLROOT" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLROOT" Name="AiPairLauncher">
        <Directory Id="INSTALLAPPDIR" Name="app">
          <Files Include="!(bindpath.PublishApp)\**">
            <Exclude Files="!(bindpath.PublishApp)\AiPairLauncher.App.exe" />
          </Files>

          <Component Id="cmpMainExe" Guid="*">
            <File Id="filMainExe" Source="!(bindpath.PublishApp)\AiPairLauncher.App.exe" KeyPath="yes" />
          </Component>
        </Directory>

        <Component Id="cmpLaunchCmd" Guid="*">
          <File Id="filLaunchCmd" Source="!(bindpath.BundleRoot)\install\launch.cmd" Name="launch.cmd" KeyPath="yes" />
        </Component>

        <Component Id="cmpPreflight" Guid="*">
          <File Id="filPreflight" Source="!(bindpath.BundleRoot)\install\preflight-check.ps1" Name="preflight-check.ps1" KeyPath="yes" />
        </Component>

        <Component Id="cmpReadme" Guid="*">
          <File Id="filReadme" Source="!(bindpath.BundleRoot)\README.md" Name="README.md" KeyPath="yes" />
        </Component>

        <Component Id="cmpLicense" Guid="*">
          <File Id="filLicense" Source="!(bindpath.BundleRoot)\LICENSE" Name="LICENSE" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="AiPairLauncher">
        <Component Id="cmpProgramMenuFolder" Guid="*">
          <Shortcut
            Id="StartMenuShortcut"
            Name="AiPairLauncher"
            Description="Launch AiPairLauncher"
            Target="[INSTALLAPPDIR]AiPairLauncher.App.exe"
            WorkingDirectory="INSTALLAPPDIR"
            Icon="AiPairLauncherIcon"
            Advertise="no" />
          <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\AiPairLauncher" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="cmpDesktopShortcut" Guid="*">
        <Shortcut
          Id="DesktopShortcut"
          Name="AiPairLauncher"
          Description="Launch AiPairLauncher"
          Target="[INSTALLAPPDIR]AiPairLauncher.App.exe"
          WorkingDirectory="INSTALLAPPDIR"
          Icon="AiPairLauncherIcon"
          Advertise="no" />
        <RegistryValue Root="HKCU" Key="Software\AiPairLauncher" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Package>
</Wix>
