<Application x:Class="AiPairLauncher.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F5F9" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9E1EC" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1E8E3E" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#EDF3FA" />
            <Setter Property="BorderBrush" Value="#C9D9EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#C9D3E0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Resources>
</Application>
