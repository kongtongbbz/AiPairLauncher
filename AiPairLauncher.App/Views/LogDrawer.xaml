<UserControl x:Class="AiPairLauncher.App.Views.LogDrawer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="12"
            CornerRadius="12"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="系统日志" />
                <Button DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Content="清空日志"
                        Click="ClearLog_Click" />
            </DockPanel>

            <TextBox Grid.Row="1"
                     Margin="0,10,0,0"
                     Padding="10"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding Core.LogText, Mode=OneWay}" />
        </Grid>
    </Border>
</UserControl>
