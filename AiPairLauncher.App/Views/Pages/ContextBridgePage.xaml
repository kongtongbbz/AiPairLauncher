<UserControl x:Class="AiPairLauncher.App.Views.Pages.ContextBridgePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="上下文桥接" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding Core.SelectedSessionDisplayName}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Core.SelectedSessionStatus}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,14"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox MinHeight="320"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Core.TransferInstruction, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="1"
                             Margin="0,12,0,0"
                             Columns="2">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="抓取行数" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding Core.LastLines, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,12,0,0"
                                  IsChecked="{Binding Core.SubmitAfterSend}"
                                  Content="发送后自动回车" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="最近发送" />
                        <TextBlock Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding Core.LastTransferSummary}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="最近失败" />
                        <TextBlock Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding Core.LastTransferFailure}" />
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2">
            <Button Margin="0,0,10,0"
                    Content="左 → 右 发送"
                    Click="SendLeftToRight_Click"
                    IsEnabled="{Binding Core.CanSend}" />
            <Button Content="右 → 左 发送"
                    Click="SendRightToLeft_Click"
                    IsEnabled="{Binding Core.CanSend}" />
        </WrapPanel>
    </Grid>
</UserControl>
