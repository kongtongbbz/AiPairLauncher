<UserControl x:Class="AiPairLauncher.App.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <UniformGrid Grid.Row="0"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Margin="0,0,0,14"
                         Columns="3">
                <Border Margin="0,0,10,0"
                        Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="会话" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding Core.SessionCounterSummary}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,0"
                        Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="待处理" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding Core.PendingQueueSummary}" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="状态" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding Core.StatusMessage}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,14"
                    Style="{DynamicResource CardBorderStyle}"
                    Visibility="{Binding Core.HasPendingSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="待处理队列" />
                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding Core.PendingSessionRecords}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,10,8"
                                        Padding="12,8"
                                        Tag="{Binding SessionId}"
                                        Click="SelectPendingSession_Click">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding HealthDisplayText}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,14,0"
                    Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="仪表盘" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="搜索、筛选并双击切换到目标会话详情。" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,14,0,12">
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="搜索" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding Core.SessionSearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <UniformGrid Margin="0,12,0,0"
                                     Columns="2">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="状态筛选" />
                                <ComboBox Margin="0,6,0,0"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          ItemsSource="{Binding Core.SessionStatusFilterOptions}"
                                          SelectedValue="{Binding Core.SelectedSessionStatusFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="分组筛选" />
                                <ComboBox Margin="0,6,0,0"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          ItemsSource="{Binding Core.SessionGroupOptions}"
                                          SelectedValue="{Binding Core.SelectedSessionGroupFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <CheckBox Margin="0,12,0,0"
                                  IsChecked="{Binding Core.ShowArchivedSessions}"
                                  Content="显示已归档会话" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Margin="0,0,10,0"
                                    Content="刷新会话"
                                    Click="RefreshSessions_Click"
                                    IsEnabled="{Binding Core.CanStart}" />
                            <Button Content="刷新依赖"
                                    Click="RefreshDependencies_Click"
                                    IsEnabled="{Binding Core.CanStart}" />
                        </WrapPanel>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Core.SessionRecords}"
                             SelectedItem="{Binding Core.SelectedSessionRecord, Mode=TwoWay}"
                             SelectionChanged="SessionList_SelectionChanged"
                             MouseDoubleClick="SessionList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        CornerRadius="16"
                                        Background="{DynamicResource CardBackgroundSoftBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="置顶 / 取消置顶"
                                                      Tag="{Binding SessionId}"
                                                      Click="TogglePinSession_Click" />
                                            <MenuItem Header="复制配置"
                                                      Tag="{Binding SessionId}"
                                                      Click="CopySessionConfig_Click" />
                                            <MenuItem Header="归档"
                                                      Tag="{Binding SessionId}"
                                                      Click="ArchiveSession_Click" />
                                            <MenuItem Header="恢复"
                                                      Tag="{Binding SessionId}"
                                                      Click="RestoreSession_Click" />
                                            <MenuItem Header="查看详情"
                                                      Tag="{Binding SessionId}"
                                                      Click="OpenSessionDetail_Click" />
                                            <MenuItem Header="打开目录"
                                                      Tag="{Binding SessionId}"
                                                      Click="OpenWorktreePath_Click" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding GroupName}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Padding="8,3"
                                                    CornerRadius="999"
                                                    Background="{DynamicResource ListBadgeBackgroundBrush}">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           Text="{Binding HealthDisplayText}" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding BadgeSummary}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding LastSeenDisplay, StringFormat=最近活动 {0}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="1"
                    Style="{DynamicResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="快速启动" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="保留高频字段，进阶参数收纳到高级选项。" />

                        <TextBlock Margin="0,14,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作目录" />
                        <DockPanel Margin="0,6,0,0">
                            <Button DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Content="浏览"
                                    Click="BrowseWorkingDirectory_Click"
                                    IsEnabled="{Binding Core.CanStart}" />
                            <TextBox Text="{Binding Core.WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作区名称" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding Core.WorkspaceName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="默认分组" />
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding Core.SessionGroupName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="启动模板" />
                        <DockPanel Margin="0,6,0,0">
                            <Button DockPanel.Dock="Right"
                                    Margin="10,0,0,0"
                                    Content="套用"
                                    Click="ApplyLaunchProfile_Click"
                                    IsEnabled="{Binding Core.CanApplyLaunchProfile}" />
                            <ComboBox SelectedValuePath="ProfileId"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding Core.LaunchProfiles}"
                                      SelectedValue="{Binding Core.SelectedLaunchProfileId, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Claude 模式" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.ClaudeModeOptions}"
                                  SelectedValue="{Binding Core.ClaudePermissionMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.AreModeSelectorsEnabled}" />

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Codex 模式" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.CodexModeOptions}"
                                  SelectedValue="{Binding Core.CodexMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.AreModeSelectorsEnabled}" />

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding Core.ModeLockHint}" />

                        <Expander Margin="0,14,0,0"
                                  Header="高级选项">
                            <StackPanel Margin="0,10,0,0">
                                <CheckBox IsChecked="{Binding Core.AutoModeEnabled}"
                                          Content="自动交互模式" />
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding Core.UseWorktree}"
                                          Content="使用受管 worktree" />

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="worktree 策略" />
                                <ComboBox Margin="0,6,0,0"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          ItemsSource="{Binding Core.WorktreeStrategyOptions}"
                                          SelectedValue="{Binding Core.WorktreeStrategy, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="右侧 pane 宽度" />
                                <Slider Margin="0,6,0,0"
                                        Minimum="20"
                                        Maximum="80"
                                        Value="{Binding Core.RightPanePercent, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="面板预设" />
                                <ComboBox Margin="0,6,0,0"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          ItemsSource="{Binding Core.PanelPresetOptions}"
                                          SelectedValue="{Binding Core.PanelPreset, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="编排模板" />
                                <ComboBox Margin="0,6,0,0"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          ItemsSource="{Binding Core.AutomationTemplateOptions}"
                                          SelectedValue="{Binding Core.SelectedAutomationTemplateKey, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,14,0,0"
                                           FontWeight="SemiBold"
                                           Text="Phase 执行器" />

                                <UniformGrid Margin="0,10,0,0" Columns="2">
                                    <StackPanel Margin="0,0,10,10">
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Phase 1" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                                  SelectedValue="{Binding Core.SelectedPhase1ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Phase 2" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                                  SelectedValue="{Binding Core.SelectedPhase2ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Phase 3" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                                  SelectedValue="{Binding Core.SelectedPhase3ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="Phase 4" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                                  SelectedValue="{Binding Core.SelectedPhase4ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Expander>

                        <Button Margin="0,16,0,0"
                                Content="启动 Ai Pair"
                                Click="StartSession_Click"
                                IsEnabled="{Binding Core.CanStart}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
