<UserControl x:Class="AiPairLauncher.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="启动模板管理" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding GuiTaskChecklistPath}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox SelectedValuePath="ProfileId"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{Binding Core.LaunchProfiles}"
                                  SelectedValue="{Binding Core.SelectedLaunchProfileId, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Margin="10,0,10,0"
                                Content="套用"
                                Click="ApplyLaunchProfile_Click"
                                IsEnabled="{Binding Core.CanApplyLaunchProfile}" />
                        <TextBox Grid.Column="2"
                                 Width="180"
                                 Text="{Binding Core.NewLaunchProfileName, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Button Margin="0,12,0,0"
                            Width="140"
                            HorizontalAlignment="Left"
                            Content="保存模板"
                            Click="SaveLaunchProfile_Click"
                            IsEnabled="{Binding Core.CanSaveLaunchProfile}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding Core.LaunchProfileSummary}" />
                </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="依赖与环境" />
                    <Button Margin="0,12,0,0"
                            Width="140"
                            HorizontalAlignment="Left"
                            Content="刷新依赖"
                            Click="RefreshDependencies_Click"
                            IsEnabled="{Binding Core.CanStart}" />
                    <DataGrid Margin="0,12,0,0"
                              Height="260"
                              ItemsSource="{Binding Core.Dependencies}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="组件" Binding="{Binding Name}" Width="100" />
                            <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="140" />
                            <DataGridTextColumn Header="提示" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="外观" />
                    <ComboBox Margin="0,12,0,0"
                              Width="140"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding Core.ThemeOptions}"
                              SelectedValue="{Binding Core.SelectedThemeMode, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="ThemeSelector_SelectionChanged" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding Core.ThemeSummary}" />
                </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="缓存与维护" />
                    <WrapPanel Margin="0,12,0,0">
                        <Button Margin="0,0,10,0"
                                Content="清理缓存"
                                Click="ClearAppCache_Click"
                                IsEnabled="{Binding Core.CanStart}" />
                        <Button Margin="0,0,10,0"
                                Content="清理当前 worktree"
                                Click="CleanupWorktree_Click"
                                IsEnabled="{Binding Core.CanStart}" />
                        <Button Content="清理孤儿 worktree"
                                Click="CleanupOrphanedWorktrees_Click"
                                IsEnabled="{Binding Core.CanStart}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
