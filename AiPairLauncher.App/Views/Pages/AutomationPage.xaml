<UserControl x:Class="AiPairLauncher.App.Views.Pages.AutomationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="自动编排工作台" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding Core.AutomationStatusDetail}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding Core.AutomationStartHint}" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right">
                        <Button Margin="0,0,10,0"
                                Content="启动"
                                Click="StartAutomation_Click"
                                IsEnabled="{Binding Core.CanStartAutomation}" />
                        <Button Content="停止"
                                Click="StopAutomation_Click"
                                IsEnabled="{Binding Core.CanStopAutomation}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <UniformGrid Margin="0,14,0,0"
                         Columns="4">
                <Border Margin="0,0,10,0" Padding="12" CornerRadius="12" Background="{DynamicResource CardBackgroundSoftBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Phase 1" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="项目调研" />
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行器" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                  SelectedValue="{Binding Core.SelectedPhase1ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPhase1Active}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Margin="0,0,10,0" Padding="12" CornerRadius="12" Background="{DynamicResource CardBackgroundSoftBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Phase 2" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="计划编排" />
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行器" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                  SelectedValue="{Binding Core.SelectedPhase2ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPhase2Active}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Margin="0,0,10,0" Padding="12" CornerRadius="12" Background="{DynamicResource CardBackgroundSoftBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Phase 3" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="任务执行" />
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行器" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                  SelectedValue="{Binding Core.SelectedPhase3ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPhase3Active}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <Border Padding="12" CornerRadius="12" Background="{DynamicResource CardBackgroundSoftBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Phase 4" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="复核验收" />
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行器" />
                        <ComboBox Margin="0,6,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding Core.PhaseExecutorOptions}"
                                  SelectedValue="{Binding Core.SelectedPhase4ExecutorKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding Core.CanEditPhaseExecutors}" />
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPhase4Active}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </UniformGrid>

            <UniformGrid Margin="0,14,0,0" Columns="2">
                <Border Margin="0,0,10,10" Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="任务文档" />
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="task.md 路径" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationTaskMdPath}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="状态" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding Core.AutomationTaskMdStatus}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="进度" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationTaskProgressSummary}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="当前任务角色" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding CurrentTaskRole}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="依赖" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding CurrentTaskDependencies}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="风险" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding CurrentTaskRisk}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行结果摘要" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding CurrentTaskExecutionSummary}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="复核摘要" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding ReviewSummary}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="当前负责人" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationActiveExecutorLabel}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="并发策略" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationParallelismPolicyLabel}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="并行组摘要" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationParallelGroupSummary}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="回放入口" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Core.AutomationHistoryReplayHint}" />
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="审批与参数" />
                        <Border Margin="0,12,0,0"
                                Padding="12"
                                CornerRadius="12"
                                Background="{DynamicResource InsetBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Core.PendingApprovalStage}" />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding Core.PendingApprovalTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Text="{Binding Core.PendingApprovalSummary}" />
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Text="{Binding Core.AutomationInterventionReason}" />
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Text="{Binding Core.PendingApprovalExecutorLabel}" />
                            </StackPanel>
                        </Border>

                        <TextBox Margin="0,12,0,0"
                                 MinHeight="76"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Core.ApprovalNote, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Margin="0,0,10,0" Content="批准并发送" Click="ApprovePlan_Click" IsEnabled="{Binding Core.CanApproveAutomation}" />
                            <Button Content="退回重拟" Click="RejectPlan_Click" IsEnabled="{Binding Core.CanRejectAutomation}" />
                        </WrapPanel>

                        <Expander Margin="0,14,0,0" Header="高级参数">
                            <UniformGrid Margin="0,10,0,0" Columns="2">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="推进策略" />
                                    <ComboBox Margin="0,6,0,0"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              ItemsSource="{Binding Core.AutomationAdvancePolicyOptions}"
                                              SelectedValue="{Binding Core.SelectedAutomationAdvancePolicyKey, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="轮询(ms)" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationPollIntervalMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="无进展超时(s)" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="抓取行数" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationCaptureLines, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="最大自动阶段数" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationMaxAutoStages, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="单阶段最大重试" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationMaxRetryPerStage, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="并发策略" />
                                    <ComboBox Margin="0,6,0,0"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              ItemsSource="{Binding Core.AutomationParallelismPolicyOptions}"
                                              SelectedValue="{Binding Core.SelectedAutomationParallelismPolicyKey, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="最大并行数" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Core.AutomationMaxParallelSubagents, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                        </Expander>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="阶段历史" />
                    <TextBox Grid.Row="1"
                             Margin="0,12,0,0"
                             MinHeight="88"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding Core.AutomationTaskPrompt, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,104,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding Core.AutomationHistoryReplayHint}" />
                    <ListBox Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Core.AutomationHistory}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        CornerRadius="10"
                                        Background="{DynamicResource CardBackgroundSoftBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayStage}" />
                                            <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding OccurredAt, StringFormat=HH:mm:ss}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource AccentBrush}" Text="{Binding SeverityLabel}" />
                                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding StatusDetail}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Text="{Binding LastPacketSummary}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Margin="0,14,0,0" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="task.md 变更历史" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="用于回放自动编排过程中的任务文档状态变化。" />
                    <ListBox Margin="0,12,0,0"
                             ItemsSource="{Binding Core.AutomationTaskMdRevisions}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        CornerRadius="10"
                                        Background="{DynamicResource CardBackgroundSoftBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding OccurredAt, StringFormat=HH:mm:ss}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding TaskMdStatus}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding ActiveExecutor}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
