<Window x:Class="AiPairLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AiPairLauncher"
        Width="1320"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/assets/AiPairLauncher.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="AiPairLauncher 控制台" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="面向 Claude 与 Codex 双窗协作的启动、审批与自动编排壳层" />
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="10,6"
                        CornerRadius="8"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding StatusMessage}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.25*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="依赖状态" />
                            <Button DockPanel.Dock="Right"
                                    Padding="14,6"
                                    Content="刷新依赖"
                                    Click="RefreshDependencies_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Dependencies}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrushSoft}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="组件" Binding="{Binding Name}" Width="100" />
                                <DataGridTemplateColumn Header="状态" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="缺失" />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                                <Setter Property="Text" Value="可用" />
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="180" />
                                <DataGridTextColumn Header="路径" Binding="{Binding ResolvedPath}" Width="*" />
                                <DataGridTextColumn Header="提示" Binding="{Binding Message}" Width="240" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,12"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,0,0,10"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="工作目录与启动" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作目录" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="10,0,0,8"
                                 Width="460"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作区名称" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="10,0,0,8"
                                    Orientation="Horizontal">
                            <TextBox Width="280"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding WorkspaceName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="10,0,0,0"
                                    Padding="12,4"
                                    Content="浏览目录"
                                    Click="BrowseWorkingDirectory_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </StackPanel>

                        <TextBlock Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Claude 模式" />
                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="10,0,0,8"
                                  Width="220"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding ClaudeModeOptions}"
                                  SelectedValue="{Binding ClaudePermissionMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding AreModeSelectorsEnabled}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Codex 模式" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="10,0,0,8"
                                  Width="220"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding CodexModeOptions}"
                                  SelectedValue="{Binding CodexMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding AreModeSelectorsEnabled}" />

                        <TextBlock Grid.Row="5"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="自动模式" />
                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="10,0,0,8">
                            <CheckBox IsChecked="{Binding AutoModeEnabled}"
                                      Content="启用自动交互编排（Claude 领导 / Codex 执行）" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding ModeLockHint}" />
                            <TextBlock Margin="0,10,0,6"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="自动模式任务目标" />
                            <TextBox MinHeight="86"
                                     Padding="8"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding AutomationTaskPrompt, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="右侧宽度(%)" />
                        <StackPanel Grid.Row="6"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Orientation="Horizontal">
                            <Slider Width="220"
                                    Minimum="10"
                                    Maximum="90"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding RightPanePercent, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="{Binding RightPanePercent, StringFormat={}{0}%}" />
                            <Button Margin="18,0,0,0"
                                    Padding="18,6"
                                    FontWeight="SemiBold"
                                    Content="启动 Ai Pair"
                                    Click="StartSession_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,10"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="上下文发送" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="抓取行数" />
                            <TextBox Width="80"
                                     Margin="10,0,18,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding LastLines, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox VerticalAlignment="Center"
                                      IsChecked="{Binding SubmitAfterSend}"
                                      Content="发送后自动回车提交" />
                        </StackPanel>

                        <TextBox Grid.Row="2"
                                 Margin="0,12,0,12"
                                 Padding="8"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="84"
                                 TextWrapping="Wrap"
                                 Text="{Binding TransferInstruction, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <Button Padding="16,6"
                                    Content="左 → 右 发送"
                                    Click="SendLeftToRight_Click"
                                    IsEnabled="{Binding CanSend}" />
                            <Button Margin="10,0,0,0"
                                    Padding="16,6"
                                    Content="右 → 左 发送"
                                    Click="SendRightToLeft_Click"
                                    IsEnabled="{Binding CanSend}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.7*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="自动交互模式" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Padding="12,5"
                                        Content="启动自动模式"
                                        Click="StartAutomation_Click"
                                        IsEnabled="{Binding CanStartAutomation}" />
                                <Button Margin="10,0,0,0"
                                        Padding="12,5"
                                        Content="停止自动模式"
                                        Click="StopAutomation_Click"
                                        IsEnabled="{Binding CanStopAutomation}" />
                            </StackPanel>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="状态" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="{Binding AutomationStatusLabel}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="说明" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding AutomationStatusDetail}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="最近包" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding AutomationLastPacketSummary}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="最近更新" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="{Binding AutomationUpdatedAt}" />
                                </Grid>

                                <Border Padding="10"
                                        CornerRadius="8"
                                        Background="#F8FBFE"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="116" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="轮询间隔(ms)" />
                                        <TextBox Grid.Row="0"
                                                 Grid.Column="1"
                                                 Width="120"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding AutomationPollIntervalMilliseconds, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="抓取行数" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,8,0,0"
                                                 Width="120"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding AutomationCaptureLines, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Text="超时(秒)" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 Margin="0,8,0,0"
                                                 Width="120"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding AutomationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                                        <CheckBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,10,0,0"
                                                  IsChecked="{Binding AutomationSubmitOnSend}"
                                                  Content="自动编排发送后自动回车提交" />
                                        <CheckBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,38,0,0"
                                                  IsChecked="{Binding AutomationObserverEnabled}"
                                                  Content="自动模式启用四格镜像视图（下方两格实时镜像 Claude/Codex 输出）" />
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,12,0,6"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="待审批计划" />

                                <Border Padding="12"
                                        CornerRadius="8"
                                        Background="#FFFDF7"
                                        BorderBrush="#E7D7A6"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="阶段" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="{Binding PendingApprovalStage}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="标题" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding PendingApprovalTitle}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="摘要" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding PendingApprovalSummary}" />

                                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="范围" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding PendingApprovalScope}" />

                                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="步骤" />
                                        <TextBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 Margin="0,8,0,0"
                                                 Padding="8"
                                                 MinHeight="78"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding PendingApprovalSteps, Mode=OneWay}" />

                                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="验收" />
                                        <TextBox Grid.Row="5"
                                                 Grid.Column="1"
                                                 Margin="0,8,0,0"
                                                 Padding="8"
                                                 MinHeight="68"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding PendingApprovalAcceptance, Mode=OneWay}" />

                                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="执行摘要" />
                                        <TextBox Grid.Row="6"
                                                 Grid.Column="1"
                                                 Margin="0,8,0,0"
                                                 Padding="8"
                                                 MinHeight="110"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding PendingApprovalCodexBrief, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,12,0,6"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="审批备注（批准时会附加给 Codex，退回时会发送给 Claude）" />
                                <TextBox Padding="8"
                                         MinHeight="72"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding ApprovalNote, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Margin="0,12,0,0"
                                            Orientation="Horizontal">
                                    <Button Padding="14,6"
                                            Content="批准并发送给 Codex"
                                            Click="ApprovePlan_Click"
                                            IsEnabled="{Binding CanApproveAutomation}" />
                                    <Button Margin="10,0,0,0"
                                            Padding="14,6"
                                            Content="退回 Claude 重拟"
                                            Click="RejectPlan_Click"
                                            IsEnabled="{Binding CanRejectAutomation}" />
                                </StackPanel>

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Text="{Binding AutomationLastError}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="3"
                                   Margin="0,0,0,12"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="最近会话信息" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="工作区" />
                        <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Text="{Binding SessionWorkspace}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="创建时间" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SessionCreatedAt}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Pane 信息" />
                        <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Text="{Binding SessionPaneInfo}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Socket" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   MaxHeight="36"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding SessionSocketPath}" />

                        <StackPanel Grid.Row="1"
                                    Grid.RowSpan="4"
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top">
                            <Button Padding="12,6"
                                    Content="加载最近会话"
                                    Click="ReloadLastSession_Click"
                                    IsEnabled="{Binding CanStart}" />
                            <Button Margin="0,8,0,0"
                                    Padding="12,6"
                                    Content="清理程序缓存"
                                    Click="ClearAppCache_Click"
                                    IsEnabled="{Binding CanStart}" />
                            <TextBlock Margin="0,8,0,0"
                                       Width="146"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Text="仅清理最近会话记录与自动提示临时文件，不删除安装文件或项目代码" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="日志 / 状态区" />
                            <Button DockPanel.Dock="Right"
                                    Padding="12,5"
                                    Content="清空日志"
                                    Click="ClearLog_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding LogText, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,8"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{Binding FooterMessage}" />
        </Border>
    </Grid>
</Window>
