<Window x:Class="AiPairLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AiPairLauncher"
        Width="1500"
        Height="940"
        MinWidth="1320"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/assets/AiPairLauncher.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                CornerRadius="18"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Text="AiPairLauncher Mission Control" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Claude / Codex 双栏协作的多会话指挥台" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ComboBox Width="120"
                              Margin="0,0,12,0"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedValue="{Binding SelectedThemeMode, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="ThemeSelector_SelectionChanged" />
                    <Border Padding="10,6"
                            Margin="0,0,12,0"
                            CornerRadius="10"
                            Background="{DynamicResource CardBackgroundSoftBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding SessionCounterSummary}" />
                    </Border>
                    <TextBox Width="240"
                             Margin="0,0,12,0"
                             Text="{Binding SessionSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,0,12,0"
                            Content="刷新会话"
                            Click="RefreshSessions_Click"
                            IsEnabled="{Binding CanStart}" />
                    <Button Content="刷新依赖"
                            Click="RefreshDependencies_Click"
                            IsEnabled="{Binding CanStart}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,14,0"
                    Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="会话目录" />
                    <TextBlock Grid.Row="1"
                               Margin="0,6,0,12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="从左侧选择会话，中间查看详情，右侧执行启动与自动编排。" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding SessionRecords}"
                             SelectedItem="{Binding SelectedSessionRecord, Mode=TwoWay}"
                             SelectionChanged="SessionList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        CornerRadius="14"
                                        Background="{DynamicResource CardBackgroundSoftBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}" />
                                        <Border Grid.Column="1"
                                                Padding="8,3"
                                                CornerRadius="999"
                                                Background="{DynamicResource ListBadgeBackgroundBrush}">
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Text="{Binding HealthDisplayText}" />
                                        </Border>

                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding WorkingDirectoryName}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding LastSeenDisplay, StringFormat=最近活动 {0}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="0,0,14,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{DynamicResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="21"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedSessionDisplayName}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding SelectedSessionStatus}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="{Binding SelectedSessionStatusDetail}" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top">
                                <Button Margin="0,0,10,10"
                                        Content="加载选中会话"
                                        Click="ReloadLastSession_Click"
                                        IsEnabled="{Binding CanStart}" />
                                <Button Margin="0,0,10,10"
                                        Content="重连会话"
                                        Click="ReconnectSession_Click"
                                        IsEnabled="{Binding CanReconnectSession}" />
                                <Button Margin="0,0,10,10"
                                        Content="聚焦 Claude"
                                        Click="FocusClaudePane_Click"
                                        IsEnabled="{Binding CanFocusSelectedSession}" />
                                <Button Margin="0,0,10,10"
                                        Content="聚焦 Codex"
                                        Click="FocusCodexPane_Click"
                                        IsEnabled="{Binding CanFocusSelectedSession}" />
                                <Button Margin="0,0,0,10"
                                        Content="清理缓存"
                                        Click="ClearAppCache_Click"
                                        IsEnabled="{Binding CanStart}" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,14,0,14"
                                 Columns="2">
                        <Border Margin="0,0,10,10"
                                Style="{DynamicResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="工作目录" />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding SelectedSessionWorkingDirectory}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,10"
                                Style="{DynamicResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="最近活动" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding SelectedSessionLastSeen}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,0"
                                Style="{DynamicResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="代理模式" />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding SelectedSessionModeSummary}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="模板 / 重连" />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding SelectedSessionLaunchProfileSummary}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedSessionReconnectSummary}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="2"
                            Style="{DynamicResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="上下文桥接" />

                            <WrapPanel Grid.Row="1"
                                       Margin="0,10,0,12">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="抓取行数" />
                                <TextBox Width="80"
                                         Margin="10,0,18,0"
                                         Text="{Binding LastLines, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox VerticalAlignment="Center"
                                          IsChecked="{Binding SubmitAfterSend}"
                                          Content="发送后自动回车提交" />
                            </WrapPanel>

                            <TextBox Grid.Row="2"
                                     MinHeight="200"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding TransferInstruction, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Grid.Row="3"
                                    Margin="0,14,0,0"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{DynamicResource InsetBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="最近错误" />
                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             MinHeight="96"
                                             MaxHeight="180"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding SelectedSessionLastError, Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <WrapPanel Grid.Row="4"
                                       Margin="0,14,0,0">
                                <Button Margin="0,0,10,0"
                                        Content="左 → 右 发送"
                                        Click="SendLeftToRight_Click"
                                        IsEnabled="{Binding CanSend}" />
                                <Button Content="右 → 左 发送"
                                        Click="SendRightToLeft_Click"
                                        IsEnabled="{Binding CanSend}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{DynamicResource CardBorderStyle}">
                        <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="新建会话" />

                        <TextBlock Grid.Row="1"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="目录" />
                        <Grid Grid.Row="1"
                              Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox MinWidth="0"
                                     Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Content="浏览"
                                    Click="BrowseWorkingDirectory_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作区" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 Text="{Binding WorkspaceName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Claude" />
                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding ClaudeModeOptions}"
                                  SelectedValue="{Binding ClaudePermissionMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding AreModeSelectorsEnabled}" />

                        <TextBlock Grid.Row="4"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Codex" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding CodexModeOptions}"
                                  SelectedValue="{Binding CodexMode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding AreModeSelectorsEnabled}" />

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="右侧宽度" />
                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="0,12,0,0"
                                    Orientation="Horizontal">
                            <Slider Width="180"
                                    Minimum="10"
                                    Maximum="90"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding RightPanePercent, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding RightPanePercent, StringFormat={}{0}%}" />
                        </StackPanel>

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Launch Profile" />
                        <Grid Grid.Row="6"
                              Grid.Column="1"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox SelectedValuePath="ProfileId"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding LaunchProfiles}"
                                      SelectedValue="{Binding SelectedLaunchProfileId, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Content="套用"
                                    Click="ApplyLaunchProfile_Click"
                                    IsEnabled="{Binding CanApplyLaunchProfile}" />
                        </Grid>

                        <TextBlock Grid.Row="7"
                                   Grid.ColumnSpan="2"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding LaunchProfileSummary}" />

                        <TextBlock Grid.Row="8"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="保存模板" />
                        <Grid Grid.Row="8"
                              Grid.Column="1"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewLaunchProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Content="保存"
                                    Click="SaveLaunchProfile_Click"
                                    IsEnabled="{Binding CanSaveLaunchProfile}" />
                        </Grid>

                        <TextBlock Grid.Row="9"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="worktree" />
                        <StackPanel Grid.Row="9"
                                    Grid.Column="1"
                                    Margin="0,12,0,0">
                            <CheckBox IsChecked="{Binding UseWorktree}"
                                      Content="为新会话创建独立 worktree" />
                            <ComboBox Margin="0,8,0,0"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding WorktreeStrategyOptions}"
                                      SelectedValue="{Binding WorktreeStrategy, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <TextBlock Grid.Row="10"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="自动模式" />
                        <StackPanel Grid.Row="10"
                                    Grid.Column="1"
                                    Margin="0,12,0,0">
                            <CheckBox IsChecked="{Binding AutoModeEnabled}"
                                      Content="启动即进入自动编排" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding ModeLockHint}" />
                        </StackPanel>

                        <Button Grid.Row="11"
                                Grid.ColumnSpan="2"
                                Margin="0,14,0,0"
                                Content="启动 Ai Pair"
                                Click="StartSession_Click"
                                IsEnabled="{Binding CanStart}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,14,0,14"
                            Style="{DynamicResource CardBorderStyle}">
                        <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="自动编排" />
                            <Button Margin="12,0,0,0"
                                    Content="启动"
                                    Click="StartAutomation_Click"
                                    IsEnabled="{Binding CanStartAutomation}" />
                            <Button Margin="10,0,0,0"
                                    Content="停止"
                                    Click="StopAutomation_Click"
                                    IsEnabled="{Binding CanStopAutomation}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding AutomationStatusDetail}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="任务目标" />
                        <TextBox Grid.Row="3"
                                 MinHeight="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding AutomationTaskPrompt, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="推进策略" />
                            <ComboBox Grid.Row="1"
                                      Margin="0,6,10,0"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding AutomationAdvancePolicyOptions}"
                                      SelectedValue="{Binding SelectedAutomationAdvancePolicyKey, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Column="1"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="轮询(ms)" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,6,0,0"
                                     Text="{Binding AutomationPollIntervalMilliseconds, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding AutomationUpdatedAt, StringFormat=最近更新 {0}}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding AutomationInterventionReason}" />
                        </Grid>

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="待审批计划" />
                        <Border Grid.Row="6"
                                Margin="0,6,0,0"
                                Padding="12"
                                CornerRadius="12"
                                Background="{DynamicResource InsetBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding PendingApprovalStage}" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding PendingApprovalTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding PendingApprovalSummary}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="7"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="审批备注" />
                        <TextBox Grid.Row="8"
                                 MinHeight="70"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ApprovalNote, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="9"
                                    Margin="0,12,0,0"
                                    Orientation="Horizontal">
                            <Button Content="批准并发送"
                                    Click="ApprovePlan_Click"
                                    IsEnabled="{Binding CanApproveAutomation}" />
                            <Button Margin="10,0,0,0"
                                    Content="退回重拟"
                                    Click="RejectPlan_Click"
                                    IsEnabled="{Binding CanRejectAutomation}" />
                        </StackPanel>

                        <TextBlock Grid.Row="10"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding AutomationLastError}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{DynamicResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="依赖摘要" />
                            <DataGrid Grid.Row="1"
                                      Margin="0,12,0,0"
                                      Height="220"
                                      ItemsSource="{Binding Dependencies}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="组件" Binding="{Binding Name}" Width="90" />
                                    <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="140" />
                                    <DataGridTemplateColumn Header="提示" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="{Binding Message}"
                                                           ToolTip="{Binding Message}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="系统日志" />
                    <Button DockPanel.Dock="Right"
                            Content="清空日志"
                            Click="ClearLog_Click"
                            IsEnabled="{Binding CanStart}" />
                </DockPanel>

                <TextBox Grid.Row="1"
                         Margin="0,12,0,0"
                         Padding="10"
                         FontFamily="Consolas"
                         FontSize="13"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding LogText, Mode=OneWay}" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Padding="12,10"
                CornerRadius="14"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{Binding FooterMessage}" />
        </Border>
    </Grid>
</Window>
