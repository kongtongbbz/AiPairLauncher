<Window x:Class="AiPairLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AiPairLauncher"
        Width="1260"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/assets/AiPairLauncher.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="AiPairLauncher 控制台" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="面向 Claude 与 Codex 双窗协作的启动与上下文转发壳层" />
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="10,6"
                        CornerRadius="8"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="{Binding StatusMessage}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.25*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="依赖状态" />
                            <Button DockPanel.Dock="Right"
                                    Padding="14,6"
                                    Content="刷新依赖"
                                    Click="RefreshDependencies_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Dependencies}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrushSoft}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="组件" Binding="{Binding Name}" Width="100" />
                                <DataGridTemplateColumn Header="状态" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="缺失" />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                                <Setter Property="Text" Value="可用" />
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="180" />
                                <DataGridTextColumn Header="路径" Binding="{Binding ResolvedPath}" Width="*" />
                                <DataGridTextColumn Header="提示" Binding="{Binding Message}" Width="240" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,12"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,0,0,10"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="工作目录与启动" />

                        <TextBlock Grid.Row="1"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作目录" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="10,0,0,8"
                                 Width="460"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="工作区名称" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="10,0,0,8"
                                    Orientation="Horizontal">
                            <TextBox Width="280"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding WorkspaceName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="10,0,0,0"
                                    Padding="12,4"
                                    Content="浏览目录"
                                    Click="BrowseWorkingDirectory_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </StackPanel>

                        <TextBlock Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Claude 模式" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="10,0,0,8"
                                    Orientation="Horizontal">
                            <ComboBox Width="220"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding ClaudeModeOptions}"
                                      SelectedValue="{Binding ClaudePermissionMode, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding CanStart}" />
                        </StackPanel>

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Codex 模式" />
                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="10,0,0,8"
                                    Orientation="Horizontal">
                            <ComboBox Width="220"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding CodexModeOptions}"
                                      SelectedValue="{Binding CodexMode, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding CanStart}" />
                        </StackPanel>

                        <TextBlock Grid.Row="5"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="右侧宽度(%)" />
                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Orientation="Horizontal">
                            <Slider Width="220"
                                    Minimum="10"
                                    Maximum="90"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding RightPanePercent, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="{Binding RightPanePercent, StringFormat={}{0}%}" />
                            <Button Margin="18,0,0,0"
                                    Padding="18,6"
                                    FontWeight="SemiBold"
                                    Content="启动 Ai Pair"
                                    Click="StartSession_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,10"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="上下文发送" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="抓取行数" />
                            <TextBox Width="80"
                                     Margin="10,0,18,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding LastLines, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox VerticalAlignment="Center"
                                      IsChecked="{Binding SubmitAfterSend}"
                                      Content="发送后自动回车提交" />
                        </StackPanel>

                        <TextBox Grid.Row="2"
                                 Margin="0,12,0,12"
                                 Padding="8"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="84"
                                 TextWrapping="Wrap"
                                 Text="{Binding TransferInstruction, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <Button Padding="16,6"
                                    Content="左 → 右 发送"
                                    Click="SendLeftToRight_Click"
                                    IsEnabled="{Binding CanSend}" />
                            <Button Margin="10,0,0,0"
                                    Padding="16,6"
                                    Content="右 → 左 发送"
                                    Click="SendRightToLeft_Click"
                                    IsEnabled="{Binding CanSend}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="3"
                                   Margin="0,0,0,12"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="最近会话信息" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="工作区" />
                        <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Text="{Binding SessionWorkspace}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="创建时间" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SessionCreatedAt}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Pane 信息" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SessionPaneInfo}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Socket" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   MaxHeight="36"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding SessionSocketPath}" />

                        <Button Grid.Row="1"
                                Grid.RowSpan="4"
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                Padding="12,6"
                                VerticalAlignment="Top"
                                Content="加载最近会话"
                                Click="ReloadLastSession_Click"
                                IsEnabled="{Binding CanStart}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="日志 / 状态区" />
                            <Button DockPanel.Dock="Right"
                                    Padding="12,5"
                                    Content="清空日志"
                                    Click="ClearLog_Click"
                                    IsEnabled="{Binding CanStart}" />
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding LogText, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,8"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1">
            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{Binding FooterMessage}" />
        </Border>
    </Grid>
</Window>
